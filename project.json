  "security": {
    "institutionIsolation": "All data scoped by institution_id except owner",
    "jwtHeader": "Authorization: Bearer <token>",
    "loginRateLimit": "50 attempts per 15 min (dev), configurable via LOGIN_RATE_LIMIT_MAX",
    "teacherAttendanceGuard": "teacher_assignments must match class_id (+ section_id)"
  },
  "fileStructure": {
    "backend": {
      "src/index.js": "Express app entry + route mounting",
      "src/controllers": "Business logic per module",
      "src/routes": "API routes",
      "src/database/migrations": "SQL migrations",
      "src/database/seed.js": "Base seed",
      "scripts/seed-full-demo.js": "Full demo data",
      "scripts/seed-peers-academic-demo.js": "Subjects + timetable only"
    },
    "frontend": {
      "src/App.jsx": "All routes",
      "src/utils/menus.js": "Sidebar menus per role",
      "src/services/authService.js": "API client wrappers",
      "src/pages/shared": "Shared pages (Students, Teachers, Attendance, etc.)",
      "src/pages/shared/AcademicSetupPage.jsx": "Principal setup guide"
    }
  }
